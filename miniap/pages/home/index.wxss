.home {
  padding-bottom: 32rpx;
}

.search-bar {
  background: #fff;
  padding: 20rpx 24rpx 18rpx;
  box-shadow: 0 6rpx 20rpx rgba(15, 23, 42, 0.03);
}
.search-input {
  display: flex;
  align-items: center;
  background: #f6f7f9;
  border: 1rpx solid #eef0f3;
  border-radius: 34rpx;
  padding: 0 24rpx;
  height: 68rpx;
}
.search-icon {
  margin-right: 12rpx;
  opacity: 0.62;
}
.search-input input {
  flex: 1;
  font-size: 28rpx;
  color: #1f2329;
}
.input-placeholder {
  color: #9aa0a6;
}

.banner {
  height: 284rpx;
  margin: 24rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}
.banner-img {
  width: 100%;
  height: 100%;
  display: block;
}
.banner-placeholder {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 46rpx 48rpx;
  background: linear-gradient(135deg, #fff7f0, #ffe3d1);
  color: #1f2329;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.banner-2 {
  background: linear-gradient(135deg, #f5f7fb, #e8eef7);
}
.banner-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 0;
}
.banner-desc {
  margin-top: 12rpx;
  color: #646a73;
  font-size: 26rpx;
}

.cat-grid {
  margin: 0 24rpx 24rpx;
  padding: 18rpx 0;
  display: flex;
  flex-wrap: wrap;
}
.cat-cell {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 18rpx 0;
  box-sizing: border-box;
}
.cat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
  background: #fff7f0;
}
.cat-icon-default {
  display: flex;
  align-items: center;
  justify-content: center;
}
.cat-icon-default .icon {
  opacity: 0.72;
}
.cat-name {
  max-width: 130rpx;
  font-size: 24rpx;
  color: #1f2329;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-title {
  margin: 4rpx 24rpx 18rpx;
}

.product-grid {
  margin: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.prod-card {
  width: 48.3%;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.prod-image {
  width: 100%;
  height: 320rpx;
  display: block;
  background: #f3f4f6;
}
.prod-image-default {
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-goods-icon {
  width: 88rpx;
  height: 88rpx;
  opacity: 0.42;
}
.prod-body {
  padding: 16rpx 16rpx 18rpx;
}
.prod-title {
  min-height: 72rpx;
  font-size: 28rpx;
  line-height: 36rpx;
  color: #1f2329;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.prod-row {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.prod-price {
  font-size: 32rpx;
  color: #ff6600;
  font-weight: 700;
}
.prod-more {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff7f0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.prod-more .icon {
  opacity: 0.62;
}
