.home {
  padding-bottom: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-bar {
  background: #fff;
  padding: 20rpx 24rpx;
}
.search-input {
  display: flex;
  align-items: center;
  background: #f1f1f1;
  border-radius: 32rpx;
  padding: 0 24rpx;
  height: 64rpx;
}
.search-icon {
  margin-right: 12rpx;
  color: #999;
}
.search-input input {
  flex: 1;
  font-size: 28rpx;
}

.banner {
  height: 280rpx;
  margin: 24rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.banner-img {
  width: 100%;
  height: 100%;
  display: block;
}
.banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #ff9966, #ff5e62);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}
.banner-2 {
  background: linear-gradient(135deg, #36d1dc, #5b86e5);
}

.cat-grid {
  background: #fff;
  margin: 0 24rpx 24rpx;
  border-radius: 16rpx;
  padding: 24rpx 0;
  display: flex;
  flex-wrap: wrap;
}
.cat-cell {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}
.cat-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 12rpx;
}
.cat-icon-default {
  background: #ffeae0;
  color: #ff6600;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}
.cat-name {
  font-size: 24rpx;
  color: #333;
}

.section-title {
  margin: 0 24rpx 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.product-grid {
  margin: 0 24rpx;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.prod-card {
  width: 48%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}
.prod-image {
  width: 100%;
  height: 320rpx;
  display: block;
}
.prod-image-default {
  background: #eee;
  color: #aaa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}
.prod-title {
  padding: 16rpx 16rpx 8rpx;
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.prod-price {
  padding: 0 16rpx 16rpx;
  font-size: 30rpx;
  color: #ff5722;
  font-weight: 600;
}

.empty {
  margin: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}
