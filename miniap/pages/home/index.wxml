<view class="home page-shell">
  <view class="search-bar">
    <view class="search-input">
      <image class="icon icon-sm search-icon" src="/assets/icons/search.png" mode="aspectFit" />
      <input
        placeholder="搜索商品"
        placeholder-class="input-placeholder"
        value="{{ keyword }}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
        confirm-type="search"
      />
    </view>
  </view>

  <swiper class="banner" autoplay circular indicator-dots interval="3000" wx:if="{{banners.length}}">
    <swiper-item wx:for="{{banners}}" wx:key="id">
      <image
        class="banner-img"
        src="{{ item.imageUrl }}"
        mode="aspectFill"
        data-banner="{{ item }}"
        bindtap="onBannerTap"
      />
    </swiper-item>
  </swiper>
  <swiper class="banner" autoplay circular indicator-dots interval="3000" wx:else>
    <swiper-item>
      <view class="banner-placeholder">
        <view class="banner-title">品质好物</view>
        <view class="banner-desc">每日精选上新</view>
      </view>
    </swiper-item>
    <swiper-item>
      <view class="banner-placeholder banner-2">
        <view class="banner-title">会员优选</view>
        <view class="banner-desc">清爽购物体验</view>
      </view>
    </swiper-item>
  </swiper>

  <view class="cat-grid card" wx:if="{{ topCategories.length }}">
    <view
      class="cat-cell"
      wx:for="{{ topCategories }}"
      wx:key="id"
      bindtap="onCategory"
      data-id="{{ item.id }}"
    >
      <image
        wx:if="{{ item.icon }}"
        class="cat-icon"
        src="{{ item.icon }}"
        mode="aspectFit"
      />
      <view wx:else class="cat-icon cat-icon-default">
        <image class="icon" src="/assets/icons/category.png" mode="aspectFit" />
      </view>
      <text class="cat-name">{{ item.name }}</text>
    </view>
  </view>

  <view class="section-title home-title">
    <text>{{ keyword ? '搜索结果' : '精选商品' }}</text>
  </view>

  <view class="product-grid" wx:if="{{ products.length }}">
    <view
      class="prod-card card"
      wx:for="{{ products }}"
      wx:key="id"
      bindtap="onProduct"
      data-id="{{ item.id }}"
    >
      <image
        wx:if="{{ item.mainImage }}"
        class="prod-image"
        src="{{ item.mainImage }}"
        mode="aspectFill"
      />
      <view wx:else class="prod-image prod-image-default">
        <image class="empty-goods-icon" src="/assets/icons/empty.png" mode="aspectFit" />
      </view>
      <view class="prod-body">
        <view class="prod-title">{{ item.name }}</view>
        <view class="prod-row">
          <view class="prod-price">¥ {{ item.minPrice }}</view>
          <view class="prod-more">
            <image class="icon icon-sm" src="/assets/icons/arrow-right.png" mode="aspectFit" />
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:elif="{{ !loading }}">
    <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
    <view class="empty-title">{{ keyword ? '暂无搜索结果' : '暂无商品' }}</view>
  </view>
</view>
