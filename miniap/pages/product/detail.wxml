<view wx:if="{{ product }}" class="detail page-shell">
  <swiper class="banner" autoplay circular indicator-dots>
    <swiper-item wx:for="{{ banners }}" wx:key="*this">
      <image src="{{ item }}" mode="aspectFill" />
    </swiper-item>
    <swiper-item wx:if="{{ banners.length === 0 }}">
      <view class="banner-empty">
        <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
        <text>暂无图片</text>
      </view>
    </swiper-item>
  </swiper>

  <view class="info card">
    <view class="price">¥ {{ product.minPrice }}<text wx:if="{{ product.minPrice !== product.maxPrice }}"> - {{ product.maxPrice }}</text></view>
    <view class="name">{{ product.name }}</view>
    <view wx:if="{{ product.subtitle }}" class="subtitle">{{ product.subtitle }}</view>
    <view class="meta">
      <text>销量 {{ product.totalSales || 0 }}</text>
      <text class="dot">·</text>
      <text>库存 {{ product.totalStock || 0 }}</text>
    </view>
  </view>

  <view class="sku-row card" bindtap="openSku">
    <view class="sku-label">
      <image class="icon icon-sm" src="/assets/icons/package.png" mode="aspectFit" />
      <text>{{ selectedSkuText || '请选择规格' }}</text>
    </view>
    <image class="icon icon-sm arrow" src="/assets/icons/arrow-right.png" mode="aspectFit" />
  </view>

  <view class="desc card">
    <view class="desc-title section-title">商品详情</view>
    <view wx:if="{{ product.description }}" class="desc-body">
      <rich-text nodes="{{ product.description }}" />
    </view>
    <view wx:else class="desc-empty">
      <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
      <text>暂无详情</text>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="cart" data-action="cart" bindtap="openSku">
      <image class="btn-icon" src="/assets/icons/cart.png" mode="aspectFit" />
      <text>加入购物车</text>
    </button>
    <button class="confirm" data-action="buy" bindtap="openSku">立即购买</button>
  </view>

  <view wx:if="{{ skuOpen }}" class="sku-mask" bindtap="closeSku">
    <view class="sku-popup" catchtap="noop">
      <view class="sku-head">
        <image
          class="sku-img"
          src="{{ (selectedSku && selectedSku.image) || product.mainImage }}"
          mode="aspectFill"
        />
        <view class="sku-meta">
          <view class="price">¥ {{ selectedSku ? selectedSku.price : product.minPrice }}</view>
          <view class="text">{{ selectedSkuText || '请选择规格' }}</view>
          <view wx:if="{{ selectedSku }}" class="stock">库存 {{ selectedSku.stock }}</view>
        </view>
        <view class="close" catchtap="closeSku">
          <image class="icon" src="/assets/icons/close.png" mode="aspectFit" />
        </view>
      </view>

      <scroll-view class="sku-body" scroll-y>
        <view wx:for="{{ product.specs }}" wx:key="id" wx:for-item="spec" wx:for-index="si" class="spec-group">
          <view class="spec-name">{{ spec.name }}</view>
          <view class="spec-values">
            <view
              wx:for="{{ spec.values }}"
              wx:key="id"
              wx:for-item="v"
              class="val {{ selectedValueIds[si] === v.id ? 'active' : '' }}"
              bindtap="onSelectVal"
              data-spec-index="{{ si }}"
              data-val-id="{{ v.id }}"
            >
              {{ v.value }}
            </view>
          </view>
        </view>

        <view class="qty-row">
          <text class="label">数量</text>
          <view class="qty">
            <view class="qty-btn" bindtap="onQtyMinus"><image class="icon icon-sm" src="/assets/icons/minus.png" mode="aspectFit" /></view>
            <text class="qty-num">{{ qty }}</text>
            <view class="qty-btn" bindtap="onQtyPlus"><image class="icon icon-sm" src="/assets/icons/plus.png" mode="aspectFit" /></view>
          </view>
        </view>
      </scroll-view>

      <button class="confirm-btn" bindtap="onConfirm" disabled="{{addingCart}}">
        {{addingCart ? '处理中...' : (skuAction === 'cart' ? '加入购物车' : '立即购买')}}
      </button>
    </view>
  </view>
</view>

<view wx:elif="{{ !loading }}" class="empty-state page-shell">
  <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
  <view class="empty-title">商品不存在</view>
</view>
