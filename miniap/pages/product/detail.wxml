<view wx:if="{{ product }}" class="detail">
  <swiper class="banner" autoplay circular indicator-dots>
    <swiper-item wx:for="{{ banners }}" wx:key="*this">
      <image src="{{ item }}" mode="aspectFill" />
    </swiper-item>
    <swiper-item wx:if="{{ banners.length === 0 }}">
      <view class="banner-empty">无图</view>
    </swiper-item>
  </swiper>

  <view class="info">
    <view class="price">¥ {{ product.minPrice }}<text wx:if="{{ product.minPrice !== product.maxPrice }}"> - {{ product.maxPrice }}</text></view>
    <view class="name">{{ product.name }}</view>
    <view wx:if="{{ product.subtitle }}" class="subtitle">{{ product.subtitle }}</view>
    <view class="meta">销量 {{ product.totalSales || 0 }} · 库存 {{ product.totalStock || 0 }}</view>
  </view>

  <view class="sku-row" bindtap="openSku">
    <text class="label">{{ selectedSkuText || '请选择规格' }}</text>
    <text class="arrow">›</text>
  </view>

  <view class="desc">
    <view class="desc-title">商品详情</view>
    <view wx:if="{{ product.description }}" class="desc-body">
      <rich-text nodes="{{ product.description }}" />
    </view>
    <view wx:else class="desc-empty">暂无详情</view>
  </view>

  <view class="bottom-bar">
    <button class="cart" data-action="cart" bindtap="openSku">加入购物车</button>
    <button class="confirm" data-action="buy" bindtap="openSku">立即购买</button>
  </view>

  <!-- SKU 浮层 -->
  <view wx:if="{{ skuOpen }}" class="sku-mask" bindtap="closeSku">
    <view class="sku-popup" catchtap="noop">
      <view class="sku-head">
        <image
          class="sku-img"
          src="{{ (selectedSku && selectedSku.image) || product.mainImage }}"
          mode="aspectFill"
        />
        <view class="sku-meta">
          <view class="price">¥ {{ selectedSku ? selectedSku.price : product.minPrice }}</view>
          <view class="text">{{ selectedSkuText || '请选择规格' }}</view>
          <view wx:if="{{ selectedSku }}" class="stock">库存 {{ selectedSku.stock }}</view>
        </view>
        <text class="close" catchtap="closeSku">×</text>
      </view>

      <scroll-view class="sku-body" scroll-y>
        <view wx:for="{{ product.specs }}" wx:key="id" wx:for-item="spec" wx:for-index="si" class="spec-group">
          <view class="spec-name">{{ spec.name }}</view>
          <view class="spec-values">
            <view
              wx:for="{{ spec.values }}"
              wx:key="id"
              wx:for-item="v"
              class="val {{ selectedValueIds[si] === v.id ? 'active' : '' }}"
              bindtap="onSelectVal"
              data-spec-index="{{ si }}"
              data-val-id="{{ v.id }}"
            >
              {{ v.value }}
            </view>
          </view>
        </view>

        <view class="qty-row">
          <text class="label">数量</text>
          <view class="qty">
            <text class="qty-btn" bindtap="onQtyMinus">-</text>
            <text class="qty-num">{{ qty }}</text>
            <text class="qty-btn" bindtap="onQtyPlus">+</text>
          </view>
        </view>
      </scroll-view>

      <button class="confirm-btn" bindtap="onConfirm" disabled="{{addingCart}}">
        {{addingCart ? '处理中...' : (skuAction === 'cart' ? '加入购物车' : '立即购买')}}
      </button>
    </view>
  </view>
</view>

<view wx:elif="{{ !loading }}" class="empty">商品不存在</view>
