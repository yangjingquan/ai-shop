.detail {
  padding-bottom: 156rpx;
}
.banner {
  width: 100%;
  height: 720rpx;
  background: #fff;
}
.banner image {
  width: 100%;
  height: 100%;
}
.banner-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #9aa0a6;
  background: #f6f7f9;
}
.info {
  margin: 20rpx 24rpx 0;
  padding: 26rpx 28rpx;
}
.info .price {
  color: #ff6600;
  font-size: 46rpx;
  font-weight: 700;
}
.info .name {
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
  line-height: 1.45;
}
.info .subtitle {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #646a73;
  line-height: 1.5;
}
.info .meta {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #9aa0a6;
}
.dot {
  color: #d6dae0;
}

.sku-row {
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sku-label {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #1f2329;
  font-size: 28rpx;
}
.sku-label text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sku-label .icon,
.arrow {
  opacity: 0.58;
}

.desc {
  margin: 16rpx 24rpx 0;
  padding: 26rpx 28rpx;
}
.desc-title {
  margin-bottom: 18rpx;
}
.desc-body {
  font-size: 26rpx;
  color: #1f2329;
  line-height: 1.7;
}
.desc-empty {
  min-height: 220rpx;
  color: #9aa0a6;
  font-size: 26rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #eef0f3;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -8rpx 28rpx rgba(15, 23, 42, 0.06);
}
.bottom-bar button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}
.bottom-bar .cart {
  background: #fff7f0;
  color: #ff6600;
}
.bottom-bar .confirm {
  background: #ff6600;
  color: #fff;
}
.btn-icon {
  width: 32rpx;
  height: 32rpx;
  opacity: 0.72;
}

.sku-mask {
  position: fixed;
  inset: 0;
  background: rgba(31, 35, 41, 0.48);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.sku-popup {
  width: 100%;
  background: #fff;
  border-radius: 28rpx 28rpx 0 0;
  max-height: 82vh;
  display: flex;
  flex-direction: column;
}
.sku-head {
  display: flex;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #eef0f3;
  position: relative;
}
.sku-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f6f7f9;
  margin-top: -48rpx;
}
.sku-meta {
  flex: 1;
  min-width: 0;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.sku-meta .price {
  color: #ff6600;
  font-size: 38rpx;
  font-weight: 700;
}
.sku-meta .text {
  font-size: 26rpx;
  color: #1f2329;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.sku-meta .stock {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-top: 6rpx;
}
.sku-head .close {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sku-head .close .icon {
  opacity: 0.52;
}

.sku-body {
  flex: 1;
  padding: 20rpx 32rpx;
  max-height: 52vh;
}
.spec-group {
  margin-bottom: 28rpx;
}
.spec-name {
  font-size: 26rpx;
  color: #1f2329;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.spec-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.val {
  padding: 13rpx 28rpx;
  border-radius: 12rpx;
  border: 1rpx solid transparent;
  background: #f6f7f9;
  color: #1f2329;
  font-size: 26rpx;
}
.val.active {
  background: #fff7f0;
  color: #ff6600;
  border-color: #ff6600;
  font-weight: 600;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0 8rpx;
}
.qty-row .label {
  font-size: 28rpx;
  color: #1f2329;
  font-weight: 600;
}
.qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.qty-btn {
  width: 56rpx;
  height: 56rpx;
  background: #f6f7f9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.qty-btn .icon {
  opacity: 0.68;
}
.qty-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  color: #1f2329;
}

.confirm-btn {
  margin: 16rpx 32rpx;
  margin-bottom: calc(16rpx + env(safe-area-inset-bottom));
  height: 88rpx;
  line-height: 88rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}
