page {
  background: #f5f5f5;
}
.detail {
  padding-bottom: 140rpx;
}
.banner {
  width: 100%;
  height: 750rpx;
  background: #fff;
}
.banner image {
  width: 100%;
  height: 100%;
}
.banner-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ccc;
}
.info {
  background: #fff;
  padding: 24rpx 32rpx;
}
.info .price {
  color: #ff4d4f;
  font-size: 44rpx;
  font-weight: 600;
}
.info .name {
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}
.info .subtitle {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #888;
}
.info .meta {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #999;
}

.sku-row {
  margin-top: 16rpx;
  background: #fff;
  padding: 28rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.sku-row .label {
  color: #333;
  font-size: 28rpx;
}
.sku-row .arrow {
  color: #ccc;
  font-size: 32rpx;
}

.desc {
  margin-top: 16rpx;
  background: #fff;
  padding: 24rpx 32rpx;
}
.desc-title {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}
.desc-body {
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
}
.desc-empty {
  color: #ccc;
  font-size: 26rpx;
  text-align: center;
  padding: 32rpx 0;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
}
.bottom-bar button {
  flex: 1;
  border-radius: 48rpx;
  font-size: 30rpx;
}
.bottom-bar .cart {
  background: #fff5e6;
  color: #ff6600;
}
.bottom-bar .confirm {
  background: #ff6600;
  color: #fff;
}

/* SKU 浮层 */
.sku-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.sku-popup {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.sku-head {
  display: flex;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  position: relative;
}
.sku-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  margin-top: -40rpx;
}
.sku-meta {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.sku-meta .price {
  color: #ff4d4f;
  font-size: 36rpx;
  font-weight: 600;
}
.sku-meta .text {
  font-size: 26rpx;
  color: #333;
  margin-top: 8rpx;
}
.sku-meta .stock {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}
.sku-head .close {
  position: absolute;
  top: 8rpx;
  right: 16rpx;
  font-size: 48rpx;
  color: #999;
  line-height: 1;
  padding: 8rpx 16rpx;
}

.sku-body {
  flex: 1;
  padding: 16rpx 32rpx;
  max-height: 50vh;
}
.spec-group {
  margin-bottom: 24rpx;
}
.spec-name {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 16rpx;
}
.spec-values {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.val {
  padding: 12rpx 28rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #333;
  font-size: 26rpx;
}
.val.active {
  background: #fff5e6;
  color: #ff6600;
  border: 1rpx solid #ff6600;
}

.qty-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
}
.qty-row .label {
  font-size: 26rpx;
  color: #333;
}
.qty {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.qty-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: #f5f5f5;
  border-radius: 50%;
  font-size: 32rpx;
  color: #333;
}
.qty-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
}

.confirm-btn {
  margin: 16rpx 32rpx;
  margin-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ff6600;
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
}

.empty {
  text-align: center;
  color: #999;
  padding: 200rpx 0;
}
