.cart-page { padding: 20rpx 20rpx 156rpx; }
.merchant-header { display: flex; align-items: center; gap: 10rpx; padding: 14rpx 4rpx; font-weight: 700; font-size: 30rpx; color: #1f2329; }
.merchant-header .icon { opacity: 0.62; }
.swipe-wrap { position: relative; overflow: hidden; margin-bottom: 14rpx; border-radius: 16rpx; }
.delete-action { position: absolute; top: 0; right: 0; bottom: 0; width: 144rpx; display: flex; flex-direction: column; gap: 6rpx; align-items: center; justify-content: center; background: #fff1f0; color: #ff4d4f; font-size: 24rpx; font-weight: 600; }
.delete-icon { width: 34rpx; height: 34rpx; }
.cart-item { position: relative; z-index: 1; display: flex; align-items: center; padding: 18rpx; background: #fff; transition: transform 0.18s ease; }
.check-btn { flex: 0 0 auto; width: 42rpx; height: 42rpx; border: 2rpx solid #d6dae0; border-radius: 50%; display: flex; align-items: center; justify-content: center; background: #fff; box-sizing: border-box; }
.check-btn.checked { border-color: #ff6600; background: #fff7f0; }
.check-btn.disabled { border-color: #eef0f3; background: #f6f7f9; }
.check-icon { width: 28rpx; height: 28rpx; }
.bottom-check { margin-right: 10rpx; }
.item-img { width: 124rpx; height: 124rpx; border-radius: 12rpx; margin-left: 18rpx; background: #f3f4f6; }
.item-info { flex: 1; padding-left: 18rpx; min-width: 0; }
.item-name { font-size: 29rpx; color: #1f2329; line-height: 38rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-spec { font-size: 24rpx; color: #9aa0a6; margin-top: 6rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 14rpx; }
.item-price { color: #ff6600; font-weight: 700; font-size: 30rpx; }
.qty-stepper { display: flex; align-items: center; border: 1rpx solid #eef0f3; border-radius: 999rpx; overflow: hidden; background: #f8f9fb; }
.qty-btn { width: 52rpx; height: 48rpx; display: flex; align-items: center; justify-content: center; }
.qty-btn .icon { opacity: 0.66; }
.qty-btn.disabled { opacity: 0.3; }
.qty-num { min-width: 56rpx; height: 48rpx; line-height: 48rpx; text-align: center; color: #1f2329; font-size: 26rpx; background: #fff; }
.unavailable-tip { display: flex; align-items: center; gap: 8rpx; color: #ff4d4f; font-size: 24rpx; margin-top: 8rpx; }
.unavailable-tip .icon { opacity: 0.7; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 20; background: rgba(255,255,255,0.98); padding: 18rpx 20rpx; padding-bottom: calc(18rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; box-shadow: 0 -8rpx 28rpx rgba(15,23,42,0.06); border-top: 1rpx solid #eef0f3; }
.select-all { display: flex; align-items: center; color: #646a73; font-size: 26rpx; }
.total { flex: 1; text-align: right; color: #ff6600; font-weight: 700; margin-right: 20rpx; font-size: 30rpx; }
.checkout-btn { height: 72rpx; line-height: 72rpx; background: #ff6600; color: #fff; border-radius: 36rpx; padding: 0 30rpx; font-size: 28rpx; font-weight: 600; }
