.cart-page { padding: 20rpx; background: #f5f5f5; }
.empty { text-align: center; padding: 100rpx; color: #999; }
.merchant-header { padding: 12rpx 0; font-weight: bold; font-size: 30rpx; }
.cart-item { display: flex; align-items: center; padding: 16rpx; background: #fff; margin-bottom: 12rpx; border-radius: 10rpx; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.item-info { flex: 1; padding: 0 16rpx; }
.item-name { font-size: 30rpx; }
.item-spec { font-size: 24rpx; color: #999; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 8rpx; }
.item-price { color: #ff6600; font-weight: bold; font-size: 30rpx; }
.item-qty { width: 80rpx; border: 1rpx solid #ddd; border-radius: 6rpx; text-align: center; font-size: 26rpx; }
.unavailable-tip { color: #ff3333; font-size: 24rpx; margin-top: 4rpx; }
.item-delete { padding: 10rpx; color: #ccc; font-size: 36rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 20rpx; display: flex; align-items: center; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); }
.total { flex: 1; text-align: right; color: #ff6600; font-weight: bold; margin-right: 20rpx; }
.checkout-btn { background: #ff6600; color: #fff; border-radius: 40rpx; padding: 10rpx 30rpx; font-size: 28rpx; }
