.cart-page { padding: 20rpx 20rpx 140rpx; background: #f5f5f5; min-height: 100vh; }
.empty { text-align: center; padding: 100rpx; color: #999; }
.merchant-header { padding: 12rpx 0; font-weight: bold; font-size: 30rpx; }
.swipe-wrap { position: relative; overflow: hidden; margin-bottom: 12rpx; border-radius: 10rpx; }
.delete-action { position: absolute; top: 0; right: 0; bottom: 0; width: 144rpx; display: flex; align-items: center; justify-content: center; background: #ff4d4f; color: #fff; font-size: 28rpx; }
.cart-item { position: relative; z-index: 1; display: flex; align-items: center; padding: 16rpx; background: #fff; border-radius: 10rpx; transition: transform 0.18s ease; }
.check-btn { flex: 0 0 auto; width: 40rpx; height: 40rpx; border: 2rpx solid #d8d8d8; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 26rpx; font-weight: 700; background: #fff; }
.check-btn.checked { border-color: #ff6600; background: #ff6600; }
.check-btn.disabled { border-color: #eee; background: #f5f5f5; }
.bottom-check { margin-right: 10rpx; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.item-info { flex: 1; padding: 0 16rpx; min-width: 0; }
.item-name { font-size: 30rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-spec { font-size: 24rpx; color: #999; margin-top: 4rpx; }
.item-bottom { display: flex; align-items: center; justify-content: space-between; margin-top: 12rpx; }
.item-price { color: #ff6600; font-weight: bold; font-size: 30rpx; }
.qty-stepper { display: flex; align-items: center; border: 1rpx solid #eee; border-radius: 999rpx; overflow: hidden; background: #fafafa; }
.qty-btn { width: 52rpx; height: 48rpx; line-height: 48rpx; text-align: center; color: #333; font-size: 32rpx; }
.qty-btn.disabled { color: #ccc; }
.qty-num { min-width: 56rpx; height: 48rpx; line-height: 48rpx; text-align: center; color: #333; font-size: 26rpx; background: #fff; }
.unavailable-tip { color: #ff3333; font-size: 24rpx; margin-top: 4rpx; }
.bottom-bar { position: fixed; bottom: 0; left: 0; right: 0; z-index: 20; background: #fff; padding: 20rpx; padding-bottom: calc(20rpx + env(safe-area-inset-bottom)); display: flex; align-items: center; box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1); }
.total { flex: 1; text-align: right; color: #ff6600; font-weight: bold; margin-right: 20rpx; }
.checkout-btn { background: #ff6600; color: #fff; border-radius: 40rpx; padding: 10rpx 30rpx; font-size: 28rpx; }
