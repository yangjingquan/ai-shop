<view class="cart-page page-shell">
  <view wx:if="{{items.length === 0}}" class="empty-state">
    <image class="empty-icon" src="/assets/icons/cart.png" mode="aspectFit" />
    <view class="empty-title">购物车是空的</view>
    <view class="empty-desc">去挑选几件喜欢的商品吧</view>
  </view>

  <block wx:for="{{merchantGroups}}" wx:key="merchantId">
    <view class="merchant-header">
      <image class="icon icon-sm" src="/assets/icons/shop.png" mode="aspectFit" />
      <text>{{item.merchantName}}</text>
    </view>
    <view class="swipe-wrap" wx:for="{{item.items}}" wx:for-item="cartItem" wx:key="id">
      <view class="delete-action" data-id="{{cartItem.id}}" bindtap="deleteItem">
        <image class="delete-icon" src="/assets/icons/trash-danger.png" mode="aspectFit" />
        <text>删除</text>
      </view>
      <view
        class="cart-item card"
        style="transform: translateX({{cartItem.swipeX}}px);"
        data-id="{{cartItem.id}}"
        bindtouchstart="onItemTouchStart"
        bindtouchmove="onItemTouchMove"
        bindtouchend="onItemTouchEnd"
        bindtouchcancel="onItemTouchCancel"
      >
        <view
          class="check-btn {{cartItem.selected ? 'checked' : ''}} {{cartItem.available === false ? 'disabled' : ''}}"
          data-id="{{cartItem.id}}"
          data-checked="{{cartItem.selected}}"
          bindtap="toggleSelect"
        >
          <image wx:if="{{cartItem.selected}}" class="check-icon" src="/assets/icons/check-primary.png" mode="aspectFit" />
        </view>
        <image class="item-img" src="{{cartItem.mainImage}}" mode="aspectFill" />
        <view class="item-info">
          <view class="item-name">{{cartItem.productName}}</view>
          <view class="item-spec">{{cartItem.specText}}</view>
          <view class="item-bottom">
            <text class="item-price">¥{{cartItem.unitPrice}}</text>
            <view class="qty-stepper">
              <view class="qty-btn {{cartItem.quantity <= 1 ? 'disabled' : ''}}" data-id="{{cartItem.id}}" bindtap="onQtyMinus">
                <image class="icon icon-sm" src="/assets/icons/minus.png" mode="aspectFit" />
              </view>
              <text class="qty-num">{{cartItem.quantity}}</text>
              <view class="qty-btn {{cartItem.stock && cartItem.quantity >= cartItem.stock ? 'disabled' : ''}}" data-id="{{cartItem.id}}" bindtap="onQtyPlus">
                <image class="icon icon-sm" src="/assets/icons/plus.png" mode="aspectFit" />
              </view>
            </view>
          </view>
          <view wx:if="{{!cartItem.available}}" class="unavailable-tip">
            <image class="icon icon-sm" src="/assets/icons/warning.png" mode="aspectFit" />
            <text>{{cartItem.unavailableReason}}</text>
          </view>
        </view>
      </view>
    </view>
  </block>

  <view class="bottom-bar" wx:if="{{items.length > 0}}">
    <view class="select-all">
      <view
        class="check-btn bottom-check {{allSelected ? 'checked' : ''}}"
        data-checked="{{allSelected}}"
        bindtap="selectAll"
      >
        <image wx:if="{{allSelected}}" class="check-icon" src="/assets/icons/check-primary.png" mode="aspectFit" />
      </view>
      <text>全选</text>
    </view>
    <text class="total">合计：¥{{totalAmount}}</text>
    <button class="checkout-btn" bindtap="goCheckout">去结算({{selectedIds.length}})</button>
  </view>
</view>
