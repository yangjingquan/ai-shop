.page {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

.row.col {
  flex-direction: column;
  align-items: flex-start;
  padding: 24rpx 0;
}

.label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
}

.input {
  flex: 1;
  font-size: 28rpx;
}

.value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.placeholder {
  color: #aaa;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}

.textarea {
  width: 100%;
  margin-top: 16rpx;
  font-size: 28rpx;
  min-height: 120rpx;
}

.submit-btn {
  margin-top: 48rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
}
