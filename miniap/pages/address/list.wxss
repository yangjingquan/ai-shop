.page {
  padding: 24rpx;
  padding-bottom: 160rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.addr-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.line {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.receiver {
  font-size: 30rpx;
  font-weight: 600;
}

.phone {
  font-size: 26rpx;
  color: #666;
}

.tag-default {
  margin-left: auto;
  font-size: 22rpx;
  color: #ff6600;
  background: #fff3eb;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.addr {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.actions {
  display: flex;
  gap: 32rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
}

.action {
  font-size: 26rpx;
  color: #ff6600;
}

.empty {
  text-align: center;
  color: #999;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.add-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #ff6600;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
}
