.page {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

.addr-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.line {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}
.line .icon,
.addr-line .icon {
  opacity: 0.58;
}
.receiver {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2329;
}
.phone-icon {
  margin-left: 8rpx;
}
.phone {
  font-size: 26rpx;
  color: #646a73;
}
.tag-default {
  margin-left: auto;
  font-size: 22rpx;
  color: #ff6600;
  background: #fff7f0;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}
.addr-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 18rpx;
}
.addr {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #1f2329;
  line-height: 1.55;
}
.actions {
  display: flex;
  gap: 30rpx;
  border-top: 1rpx solid #eef0f3;
  padding-top: 18rpx;
}
.action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  color: #ff6600;
}
.action.danger {
  color: #ff4d4f;
}
.action .icon {
  opacity: 0.68;
}
.add-btn {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 32rpx;
  bottom: calc(32rpx + env(safe-area-inset-bottom));
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #ff6600;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(255, 102, 0, 0.2);
}
.add-icon {
  width: 30rpx;
  height: 30rpx;
}
