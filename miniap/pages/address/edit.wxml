<view class="page page-shell">
  <view class="form-group card">
    <view class="row">
      <image class="field-icon" src="/assets/icons/user.png" mode="aspectFit" />
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入姓名" placeholder-class="placeholder" value="{{ form.receiver }}" bindinput="onReceiver" />
    </view>
    <view class="row">
      <image class="field-icon" src="/assets/icons/phone.png" mode="aspectFit" />
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" placeholder-class="placeholder" maxlength="11" type="number" value="{{ form.phone }}" bindinput="onPhone" />
    </view>
    <picker mode="region" bindchange="onRegionChange">
      <view class="row">
        <image class="field-icon" src="/assets/icons/location.png" mode="aspectFit" />
        <text class="label">所在地区</text>
        <view class="value">
          <text wx:if="{{ form.region }}">{{ form.region }}</text>
          <text wx:else class="placeholder">请选择省/市/区</text>
        </view>
        <image class="arrow" src="/assets/icons/arrow-right.png" mode="aspectFit" />
      </view>
    </picker>
    <view class="row col">
      <view class="col-head">
        <image class="field-icon" src="/assets/icons/edit.png" mode="aspectFit" />
        <text class="label">详细地址</text>
      </view>
      <textarea class="textarea" placeholder="街道、楼栋、门牌号等" placeholder-class="placeholder" value="{{ form.detail }}" bindinput="onDetail" />
    </view>
    <view class="row">
      <image class="field-icon" src="/assets/icons/check.png" mode="aspectFit" />
      <text class="label">设为默认</text>
      <view class="value"></view>
      <switch checked="{{ form.isDefault }}" color="#ff6600" bindchange="onDefaultChange" />
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit">保存</button>
</view>
