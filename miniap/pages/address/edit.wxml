<view class="page">
  <view class="form-group">
    <view class="row">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入姓名" value="{{ form.receiver }}" bindinput="onReceiver" />
    </view>
    <view class="row">
      <text class="label">手机号</text>
      <input class="input" placeholder="请输入手机号" maxlength="11" type="number" value="{{ form.phone }}" bindinput="onPhone" />
    </view>
    <picker mode="region" bindchange="onRegionChange">
      <view class="row">
        <text class="label">所在地区</text>
        <view class="value">
          <text wx:if="{{ form.region }}">{{ form.region }}</text>
          <text wx:else class="placeholder">请选择省/市/区</text>
        </view>
        <text class="arrow">›</text>
      </view>
    </picker>
    <view class="row col">
      <text class="label">详细地址</text>
      <textarea class="textarea" placeholder="街道、楼栋、门牌号等" value="{{ form.detail }}" bindinput="onDetail" />
    </view>
    <view class="row">
      <text class="label">设为默认</text>
      <switch checked="{{ form.isDefault }}" color="#ff6600" bindchange="onDefaultChange" />
    </view>
  </view>

  <button class="submit-btn" bindtap="onSubmit">保存</button>
</view>
