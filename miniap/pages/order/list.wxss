.order-list-page { padding: 20rpx 20rpx 128rpx; }
.tabs { white-space: nowrap; background: #fff; margin-bottom: 20rpx; border-radius: 16rpx; border: 1rpx solid #eef0f3; box-shadow: 0 8rpx 24rpx rgba(15,23,42,0.04); }
.tab { display: inline-flex; align-items: center; justify-content: center; min-width: 116rpx; height: 76rpx; padding: 0 18rpx; font-size: 26rpx; color: #646a73; position: relative; }
.tab.active { color: #ff6600; font-weight: 700; }
.tab.active::after { content: ''; position: absolute; left: 26rpx; right: 26rpx; bottom: 0; height: 4rpx; border-radius: 4rpx; background: #ff6600; }
.order-card { margin-bottom: 20rpx; padding: 22rpx; }
.card-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 16rpx; border-bottom: 1rpx solid #eef0f3; }
.merchant { display: flex; align-items: center; gap: 10rpx; min-width: 0; font-size: 28rpx; font-weight: 600; color: #1f2329; }
.merchant text { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.merchant .icon { opacity: 0.62; }
.status { flex: 0 0 auto; font-size: 25rpx; font-weight: 600; }
.s0 { color: #ff6600; }
.s1 { color: #1677ff; }
.s2 { color: #1677ff; }
.s3 { color: #2f9e44; }
.s4 { color: #9aa0a6; }
.card-body { display: flex; align-items: center; padding: 18rpx 0; }
.item-img { width: 124rpx; height: 124rpx; border-radius: 12rpx; background: #f3f4f6; }
.item-info { flex: 1; min-width: 0; padding: 0 16rpx; }
.summary { font-size: 28rpx; color: #1f2329; line-height: 38rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.count { margin-top: 8rpx; font-size: 24rpx; color: #9aa0a6; }
.arrow { opacity: 0.38; }
.card-footer { text-align: right; color: #646a73; border-top: 1rpx solid #eef0f3; padding-top: 16rpx; font-size: 26rpx; }
.amount { color: #ff6600; font-weight: 700; font-size: 30rpx; }
