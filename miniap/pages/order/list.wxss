.order-list-page { padding: 20rpx; background: #f5f5f5; }
.tabs { display: flex; background: #fff; margin-bottom: 20rpx; border-radius: 10rpx; }
.tab { flex: 1; text-align: center; padding: 20rpx 0; font-size: 28rpx; color: #666; }
.tab.active { color: #ff6600; font-weight: bold; border-bottom: 4rpx solid #ff6600; }
.empty { text-align: center; padding: 100rpx; color: #999; }
.order-card { background: #fff; margin-bottom: 20rpx; border-radius: 10rpx; padding: 20rpx; }
.card-header { display: flex; justify-content: space-between; padding-bottom: 12rpx; border-bottom: 1rpx solid #eee; }
.status { font-size: 26rpx; }
.s0 { color: #ff6600; }
.s1 { color: #1890ff; }
.s2 { color: #1890ff; }
.s3 { color: #999; }
.s4 { color: #999; }
.card-body { display: flex; padding: 16rpx 0; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.item-info { flex: 1; padding: 0 16rpx; font-size: 28rpx; }
.card-footer { text-align: right; font-weight: bold; color: #ff6600; border-top: 1rpx solid #eee; padding-top: 12rpx; }
