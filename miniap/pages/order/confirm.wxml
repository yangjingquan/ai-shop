<view class="confirm-page page-shell">
  <view class="no-address-card card" wx:if="{{noAddress}}">
    <image class="empty-icon" src="/assets/icons/location.png" mode="aspectFit" />
    <view class="no-address-title">还没有收货地址</view>
    <view class="no-address-desc">请先到【我的】页面设置收货地址，再返回提交订单。</view>
    <button class="go-my-btn" bindtap="goMy">去我的页面设置</button>
  </view>

  <view class="section card" wx:if="{{preview}}">
    <view class="section-title">收货地址</view>
    <view class="address-card" bindtap="chooseAddress">
      <image class="icon location-icon" src="/assets/icons/location.png" mode="aspectFit" />
      <view class="address-info">
        <view class="receiver-line">{{preview.address.receiver}} {{preview.address.phone}}</view>
        <view class="address-text">{{preview.address.region}} {{preview.address.detail}}</view>
        <view class="address-change">点击切换收货地址</view>
      </view>
      <image class="icon icon-sm arrow" src="/assets/icons/arrow-right.png" mode="aspectFit" />
    </view>
  </view>

  <view class="section card" wx:if="{{preview}}">
    <view class="section-title">商品明细</view>
    <block wx:for="{{preview.groups}}" wx:key="merchantId">
      <view class="merchant-header">
        <image class="icon icon-sm" src="/assets/icons/shop.png" mode="aspectFit" />
        <text>{{item.merchantName}}</text>
      </view>
      <view class="order-item" wx:for="{{item.items}}" wx:key="cartItemId">
        <image class="item-img" src="{{item.mainImage}}" mode="aspectFill" />
        <view class="item-info">
          <view class="item-name">{{item.productName}}</view>
          <view class="spec">{{item.specText}}</view>
          <view wx:if="{{!item.available}}" class="unavailable-tip">
            <image class="icon icon-sm" src="/assets/icons/warning.png" mode="aspectFit" />
            <text>{{item.unavailableReason}}</text>
          </view>
        </view>
        <view class="item-right">
          <text class="unit">¥{{item.unitPrice}} x {{item.quantity}}</text>
          <text class="subtotal">¥{{item.subtotal}}</text>
        </view>
      </view>
      <view class="group-total">
        小计：<text>¥{{item.payAmount}}</text>（免运费）
      </view>
    </block>
  </view>

  <view class="bottom-bar" wx:if="{{!noAddress}}">
    <text>合计：<text class="amount">¥{{preview.totalAmount || '0.00'}}</text></text>
    <button class="submit-btn" bindtap="submitOrder" disabled="{{submitting}}">
      {{submitting ? '提交中...' : '提交订单'}}
    </button>
  </view>
</view>
