<view class="detail-page page-shell" wx:if="{{order}}">
  <view class="status-bar card s{{order.status}}">
    <image class="status-icon" src="/assets/icons/order.png" mode="aspectFit" />
    <text>{{order.statusText}}</text>
  </view>

  <view class="address-card card">
    <image class="icon location-icon" src="/assets/icons/location.png" mode="aspectFit" />
    <view class="address-info">
      <view class="receiver-line">{{order.address.receiver}} {{order.address.phone}}</view>
      <view class="address-text">{{order.address.region}} {{order.address.detail}}</view>
    </view>
  </view>

  <view class="merchant-name">
    <image class="icon icon-sm" src="/assets/icons/shop.png" mode="aspectFit" />
    <text>{{order.merchantName}}</text>
  </view>

  <view class="items-card card">
    <view class="order-item" wx:for="{{order.items}}" wx:key="skuId">
      <image class="item-img" src="{{item.mainImage}}" mode="aspectFill" />
      <view class="item-info">
        <view class="item-name">{{item.productName}}</view>
        <view class="spec">{{item.specText}}</view>
        <view class="unit">¥{{item.unitPrice}} x {{item.quantity}}</view>
      </view>
      <text class="subtotal">¥{{item.subtotal}}</text>
    </view>
  </view>

  <view class="amount-card card">
    <view class="amount-row">
      <text>商品金额</text><text>¥{{order.totalAmount}}</text>
    </view>
    <view class="amount-row">
      <text>运费</text><text>¥{{order.freightAmount}}</text>
    </view>
    <view class="amount-row total">
      <text>实付款</text><text>¥{{order.payAmount}}</text>
    </view>
  </view>

  <view class="order-info card">
    <view class="info-row">
      <text>订单号</text><text>{{order.orderNo}}</text>
    </view>
    <view class="info-row">
      <text>创建时间</text><text>{{order.createdAt}}</text>
    </view>
    <view class="info-row" wx:if="{{order.payTime}}">
      <text>支付时间</text><text>{{order.payTime}}</text>
    </view>
  </view>

  <view class="actions" wx:if="{{order.status === 0}}">
    <button class="cancel-btn" bindtap="cancelOrder">取消订单</button>
    <button class="pay-btn" bindtap="mockPay">模拟支付</button>
  </view>
</view>
