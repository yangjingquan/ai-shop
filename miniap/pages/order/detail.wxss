.detail-page { padding: 20rpx 20rpx 48rpx; }
.status-bar { margin-bottom: 20rpx; padding: 30rpx 24rpx; display: flex; align-items: center; justify-content: center; gap: 14rpx; font-size: 36rpx; font-weight: 700; }
.status-icon { width: 42rpx; height: 42rpx; opacity: 0.72; }
.s0 { color: #ff6600; background: #fff7f0; }
.s1 { color: #1677ff; }
.s2 { color: #1677ff; }
.s3 { color: #2f9e44; }
.s4 { color: #9aa0a6; }
.address-card { display: flex; align-items: flex-start; padding: 24rpx; margin-bottom: 20rpx; font-size: 28rpx; line-height: 1.6; }
.location-icon { width: 40rpx; height: 40rpx; margin-right: 16rpx; opacity: 0.68; }
.address-info { flex: 1; min-width: 0; }
.receiver-line { color: #1f2329; font-weight: 600; }
.address-text { margin-top: 6rpx; color: #646a73; }
.merchant-name { display: flex; align-items: center; gap: 10rpx; padding: 12rpx 4rpx 16rpx; font-weight: 700; font-size: 30rpx; color: #1f2329; }
.merchant-name .icon { opacity: 0.62; }
.items-card { overflow: hidden; margin-bottom: 20rpx; }
.order-item { display: flex; padding: 18rpx; border-bottom: 1rpx solid #eef0f3; }
.order-item:last-child { border-bottom: none; }
.item-img { width: 124rpx; height: 124rpx; border-radius: 12rpx; background: #f3f4f6; }
.item-info { flex: 1; min-width: 0; padding: 0 16rpx; }
.item-name { font-size: 28rpx; color: #1f2329; line-height: 38rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.spec { color: #9aa0a6; font-size: 24rpx; margin-top: 6rpx; }
.unit { color: #646a73; font-size: 24rpx; margin-top: 10rpx; }
.subtotal { flex: 0 0 auto; font-weight: 700; color: #ff6600; font-size: 28rpx; }
.amount-card { overflow: hidden; margin-bottom: 20rpx; }
.amount-row { display: flex; justify-content: space-between; padding: 18rpx 22rpx; font-size: 28rpx; color: #646a73; border-bottom: 1rpx solid #eef0f3; }
.amount-row:last-child { border-bottom: none; }
.amount-row.total { font-weight: 700; font-size: 32rpx; color: #ff6600; }
.order-info { padding: 8rpx 22rpx; font-size: 25rpx; color: #646a73; line-height: 1.7; }
.info-row { display: flex; justify-content: space-between; gap: 24rpx; padding: 14rpx 0; border-bottom: 1rpx solid #eef0f3; }
.info-row:last-child { border-bottom: none; }
.info-row text:last-child { flex: 1; text-align: right; color: #1f2329; word-break: break-all; }
.actions { display: flex; justify-content: flex-end; gap: 20rpx; padding: 30rpx 0; }
.cancel-btn, .pay-btn { height: 72rpx; line-height: 72rpx; border-radius: 36rpx; padding: 0 34rpx; font-size: 28rpx; margin: 0; }
.cancel-btn { border: 1rpx solid #d6dae0; color: #646a73; background: #fff; }
.pay-btn { background: #ff6600; color: #fff; }
