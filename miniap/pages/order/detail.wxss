.detail-page { padding: 20rpx; background: #f5f5f5; }
.status-bar { text-align: center; padding: 30rpx; font-size: 36rpx; font-weight: bold; }
.s0 { color: #ff6600; }
.s1 { color: #1890ff; }
.s2 { color: #1890ff; }
.s3 { color: #52c41a; }
.s4 { color: #999; }
.address-card { background: #fff; padding: 20rpx; border-radius: 10rpx; margin-bottom: 20rpx; font-size: 28rpx; line-height: 1.6; }
.merchant-name { padding: 12rpx 0; font-weight: bold; font-size: 30rpx; }
.order-item { display: flex; padding: 16rpx; background: #fff; margin-bottom: 2rpx; }
.item-img { width: 120rpx; height: 120rpx; border-radius: 8rpx; }
.item-info { flex: 1; padding: 0 16rpx; }
.spec { color: #999; font-size: 24rpx; }
.subtotal { font-weight: bold; color: #ff6600; }
.amount-row { display: flex; justify-content: space-between; padding: 16rpx; background: #fff; font-size: 28rpx; }
.amount-row.total { font-weight: bold; font-size: 32rpx; color: #ff6600; }
.order-info { background: #fff; padding: 20rpx; margin-top: 20rpx; font-size: 24rpx; color: #999; line-height: 1.8; border-radius: 10rpx; }
.actions { display: flex; justify-content: flex-end; gap: 20rpx; padding: 30rpx 0; }
.cancel-btn { border: 1rpx solid #999; border-radius: 40rpx; padding: 16rpx 30rpx; font-size: 28rpx; }
.pay-btn { background: #ff6600; color: #fff; border-radius: 40rpx; padding: 16rpx 30rpx; font-size: 28rpx; }
