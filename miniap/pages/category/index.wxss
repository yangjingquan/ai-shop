.cat-page {
  display: flex;
  height: 100vh;
  overflow: hidden;
}

.left-tabs {
  width: 184rpx;
  background: #fff;
  border-right: 1rpx solid #eef0f3;
  box-sizing: border-box;
}
.tab {
  position: relative;
  min-height: 92rpx;
  padding: 0 18rpx 0 22rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: #646a73;
  text-align: center;
}
.tab text {
  max-width: 136rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tab.active {
  background: #fff7f0;
  color: #ff6600;
  font-weight: 600;
}
.tab.active::before {
  content: '';
  position: absolute;
  left: 0;
  top: 28rpx;
  width: 6rpx;
  height: 36rpx;
  border-radius: 0 6rpx 6rpx 0;
  background: #ff6600;
}
.empty-tab,
.empty-products {
  padding: 40rpx 16rpx;
  color: #9aa0a6;
  font-size: 24rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}
.empty-mini-icon {
  width: 64rpx;
  height: 64rpx;
  opacity: 0.52;
}

.right-content {
  flex: 1;
  padding: 20rpx 18rpx 128rpx;
  box-sizing: border-box;
}
.sub-section {
  margin-bottom: 28rpx;
}
.sub-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2329;
  padding: 8rpx 2rpx 16rpx;
}
.sub-title .icon {
  opacity: 0.62;
}
.sub-products {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}
.prod {
  width: 48.5%;
  padding: 12rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}
.prod-img {
  width: 100%;
  height: 206rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  display: block;
}
.prod-img-empty {
  display: flex;
  align-items: center;
  justify-content: center;
}
.empty-prod-icon {
  width: 72rpx;
  height: 72rpx;
  opacity: 0.42;
}
.prod-name {
  min-height: 64rpx;
  font-size: 24rpx;
  color: #1f2329;
  line-height: 32rpx;
  margin-top: 12rpx;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.prod-price {
  font-size: 28rpx;
  color: #ff6600;
  font-weight: 700;
  margin-top: 8rpx;
}
.empty-products {
  width: 100%;
  box-sizing: border-box;
}
.empty-content {
  min-height: 520rpx;
}
