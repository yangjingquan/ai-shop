.cat-page {
  display: flex;
  height: 100vh;
  background: #f5f5f5;
}

.left-tabs {
  width: 180rpx;
  background: #fff;
  border-right: 1rpx solid #eee;
}
.tab {
  padding: 28rpx 16rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  border-left: 4rpx solid transparent;
}
.tab.active {
  background: #f5f5f5;
  color: #ff6600;
  border-left-color: #ff6600;
  font-weight: 600;
}
.empty-tab {
  padding: 32rpx 16rpx;
  color: #999;
  font-size: 24rpx;
  text-align: center;
}

.right-content {
  flex: 1;
  padding: 16rpx;
}
.sub-section {
  margin-bottom: 24rpx;
}
.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  padding: 12rpx 8rpx;
}
.sub-products {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.prod {
  width: calc(50% - 6rpx);
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
}
.prod-img {
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}
.prod-name {
  font-size: 24rpx;
  color: #333;
  margin-top: 8rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}
.prod-price {
  font-size: 26rpx;
  color: #ff6600;
  font-weight: 600;
  margin-top: 4rpx;
}
.empty-products {
  width: 100%;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
  text-align: center;
}
.empty-content {
  padding: 64rpx 0;
  color: #999;
  font-size: 26rpx;
  text-align: center;
}
