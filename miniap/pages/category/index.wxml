<view class="cat-page page-shell">
  <scroll-view class="left-tabs" scroll-y>
    <view
      wx:for="{{ topCats }}"
      wx:key="id"
      class="tab {{ activeTopId === item.id ? 'active' : '' }}"
      bindtap="onTopTab"
      data-id="{{ item.id }}"
    >
      <text>{{ item.name }}</text>
    </view>
    <view wx:if="{{ topCats.length === 0 && !loading }}" class="empty-tab">
      <image class="empty-mini-icon" src="/assets/icons/empty.png" mode="aspectFit" />
      <text>暂无分类</text>
    </view>
  </scroll-view>

  <scroll-view class="right-content" scroll-y>
    <view wx:for="{{ subCats }}" wx:key="id" class="sub-section">
      <view class="sub-title">
        <image class="icon icon-sm" src="/assets/icons/category.png" mode="aspectFit" />
        <text>{{ item.name }}</text>
      </view>
      <view class="sub-products">
        <view
          wx:for="{{ item.products }}"
          wx:key="id"
          wx:for-item="p"
          class="prod card"
          bindtap="onProduct"
          data-id="{{ p.id }}"
        >
          <image wx:if="{{ p.mainImage }}" class="prod-img" src="{{ p.mainImage }}" mode="aspectFill" />
          <view wx:else class="prod-img prod-img-empty">
            <image class="empty-prod-icon" src="/assets/icons/empty.png" mode="aspectFit" />
          </view>
          <view class="prod-name">{{ p.name }}</view>
          <view class="prod-price">¥ {{ p.minPrice }}</view>
        </view>
        <view wx:if="{{ item.products.length === 0 }}" class="empty-products">
          <image class="empty-mini-icon" src="/assets/icons/empty.png" mode="aspectFit" />
          <text>暂无商品</text>
        </view>
      </view>
    </view>
    <view wx:if="{{ subCats.length === 0 && !loading }}" class="empty-state empty-content">
      <image class="empty-icon" src="/assets/icons/empty.png" mode="aspectFit" />
      <view class="empty-title">该分类下暂无子分类</view>
    </view>
  </scroll-view>
</view>
