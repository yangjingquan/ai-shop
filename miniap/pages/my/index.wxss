.my-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.user-card {
  display: flex;
  align-items: center;
  padding: 40rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.avatar-btn {
  width: 120rpx;
  height: 120rpx;
  margin: 0 24rpx 0 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #ddd;
}

.info {
  flex: 1;
}

.nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.nickname-input {
  min-height: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.phone-row {
  display: flex;
  align-items: center;
}

.phone {
  font-size: 26rpx;
  color: #999;
}

.bind-btn {
  margin: 0;
  font-size: 24rpx;
}

.menu {
  margin-top: 20rpx;
  background: #fff;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  font-size: 30rpx;
  color: #333;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item-hover {
  background: #f8f8f8;
}

.arrow {
  color: #ccc;
  font-size: 36rpx;
}
