.my-page {
  padding: 24rpx;
}
.user-card {
  display: flex;
  align-items: center;
  padding: 34rpx 30rpx;
  background: linear-gradient(135deg, #ffffff, #fff8f2);
}
.avatar-btn {
  position: relative;
  width: 124rpx;
  height: 124rpx;
  margin: 0 24rpx 0 0;
  padding: 0;
  border-radius: 50%;
  background: transparent;
  line-height: 1;
  overflow: visible;
}
.avatar {
  width: 124rpx;
  height: 124rpx;
  border-radius: 50%;
  background: #f6f7f9;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 20rpx rgba(15,23,42,0.08);
}
.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  background: #ff6600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid #fff;
}
.badge-icon {
  width: 22rpx;
  height: 22rpx;
}
.info {
  flex: 1;
  min-width: 0;
}
.nickname-input {
  min-height: 48rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2329;
  margin-bottom: 14rpx;
}
.placeholder {
  color: #9aa0a6;
}
.phone-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.phone-row .icon {
  opacity: 0.58;
}
.phone {
  font-size: 26rpx;
  color: #646a73;
}
.bind-btn {
  margin: 0;
  padding: 0 20rpx;
  height: 54rpx;
  line-height: 54rpx;
  border-radius: 27rpx;
  font-size: 24rpx;
  color: #ff6600;
  background: #fff7f0;
}
.menu {
  margin-top: 20rpx;
  overflow: hidden;
}
.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 28rpx;
  font-size: 30rpx;
  color: #1f2329;
  border-bottom: 1rpx solid #eef0f3;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-left {
  display: flex;
  align-items: center;
  gap: 14rpx;
}
.menu-icon {
  width: 34rpx;
  height: 34rpx;
  opacity: 0.62;
}
.arrow {
  opacity: 0.38;
}
.menu-item-hover {
  background: #f8f9fb;
}
