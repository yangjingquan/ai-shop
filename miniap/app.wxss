page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', sans-serif;
  font-size: 28rpx;
  color: #1f2329;
  background: #f6f7f9;
}

button {
  font-family: inherit;
}

button::after {
  border: none;
}

.page-shell {
  min-height: 100vh;
  background: #f6f7f9;
  box-sizing: border-box;
}

.card {
  background: #fff;
  border: 1rpx solid #eef0f3;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #1f2329;
  font-size: 30rpx;
  font-weight: 600;
}

.price,
.price-strong {
  color: #ff6600;
  font-weight: 700;
}

.muted {
  color: #646a73;
}

.subtle {
  color: #9aa0a6;
}

.icon {
  width: 32rpx;
  height: 32rpx;
  display: inline-block;
  flex: 0 0 auto;
}

.icon-sm {
  width: 28rpx;
  height: 28rpx;
}

.icon-lg {
  width: 72rpx;
  height: 72rpx;
}

.primary-btn {
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  background: #ff6600;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
}

.outline-btn {
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #fff7f0;
  color: #ff6600;
  font-size: 28rpx;
  text-align: center;
}

.empty-state {
  min-height: 360rpx;
  padding: 96rpx 48rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #9aa0a6;
  text-align: center;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  opacity: 0.72;
}

.empty-title {
  color: #646a73;
  font-size: 28rpx;
  font-weight: 500;
}

.empty-desc {
  margin-top: 8rpx;
  color: #9aa0a6;
  font-size: 24rpx;
}
