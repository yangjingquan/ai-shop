spring:
  datasource:
    url: jdbc:mysql://${DB_HOST}:${DB_PORT}/shop?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
    username: ${DB_USER}
    password: ${DB_PASSWORD}
  data:
    redis:
      host: ${REDIS_HOST}
      port: ${REDIS_PORT}
      password: ${REDIS_PASSWORD}

logging:
  level:
    root: INFO
    com.shop: INFO
  file:
    name: logs/shop-server.log
